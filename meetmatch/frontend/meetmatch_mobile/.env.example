# Backend API base URL
# Default: http://192.168.4.28:8000 (replace with your Mac's LAN IP)
# For simulators/emulators, this usually works if on the same network
# For physical devices, update to your Mac's actual LAN IP
BACKEND_LAN_IP=192.168.4.28
EXPO_PUBLIC_API_BASE_URL=http://${BACKEND_LAN_IP}:8000
